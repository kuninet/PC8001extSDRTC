.DS_Store
*.bak

# 外部ツール本体(入手方法は tools/README.md を参照。再配布しないため含めない)
/tools/*
!/tools/README.md

# 外部資料(データシート等。第三者配布物のため含めない。入手方法は external/README.md)
/external/*
!/external/README.md

# tools80 がソースの隣に出力する一時ファイル
test/*.cmt

# MPLAB X / XC8 ビルド生成物
build/
dist/
*.o
*.elf
*.hex
*.map
*.lst
*.cof
nbproject/private/

# KiCAD(本体の .kicad_pro/.kicad_sch/.kicad_pcb と カスタムシンボル *.kicad_sym /
# sym-lib-table はコミットする。以下のローカル設定・バックアップ・生成物は除外)
*-bak
*.bak
fp-info-cache
*.kicad_prl
*.lck
~*.lck
*-backups/
.history/

# Freerouting の中間ファイル(回路図/基板から再生成可能)
*.dsn
*.ses
*.rules

# 空・未参照のKiCad自動生成ライブラリ
New_Library.kicad_sym
